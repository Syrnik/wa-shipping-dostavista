{
  "name": "dostavista_shipping_plugin",
  "description": "Dostavista shipping plugin (non-official, 3rd party) interface for Webasyst",
  "license": "UNLICENSED",
  "scripts": {
    "dostavista-shipping-settings-legacy-dev": "set NODE_OPTIONS=--openssl-legacy-provider && node ./node_modules/webpack/bin/webpack --config webpack.settings.config.js --mode development --display-error-details --watch",
    "dostavista-shipping-settings-legacy-prod": "set NODE_OPTIONS=--openssl-legacy-provider && node ./node_modules/webpack/bin/webpack --config webpack.settings.config.js --mode production --display-error-details"
  },
  "dependencies": {
    "dateformat": "^3.0.3",
    "v-calendar": "^1.0.8",
    "vue": "^2.6.14",
    "vuedraggable": "^2.24.3",
    "vuejs-datepicker": "^1.6.2"
  },
  "devDependencies": {
    "@babel/core": "^7.14.8",
    "@babel/plugin-syntax-dynamic-import": "^7.8.3",
    "@babel/plugin-transform-runtime": "^7.14.5",
    "@babel/polyfill": "^7.12.1",
    "@babel/preset-env": "^7.14.9",
    "@babel/runtime": "^7.14.8",
    "babel-loader": "^8.2.2",
    "clean-webpack-plugin": "^2.0.2",
    "cross-env": "^5.2.1",
    "css-loader": "^2.1.1",
    "path": "^0.12.7",
    "stylus": "^0.54.8",
    "stylus-loader": "^3.0.2",
    "terser-webpack-plugin": "^1.4.5",
    "uglifyjs-webpack-plugin": "^2.2.0",
    "vue-loader": "^15.9.7",
    "vue-template-compiler": "^2.6.14",
    "webpack": "^4.46.0",
    "webpack-cli": "^3.3.12",
    "webpack-merge": "^4.2.2"
  }
}
